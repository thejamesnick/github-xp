{
  "name": "github-xp",
  "version": "1.0.0",
  "description": "Extract GitHub experience into AI-ready data formats",
  "type": "module",
  "bin": {
    "gh-xp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node --format esm && chmod +x dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "bun run test && bun run build",
    "start": "bun run src/index.ts"
  },
  "keywords": [
    "github",
    "resume",
    "cli",
    "experience",
    "portfolio",
    "ai",
    "career"
  ],
  "author": "Nicholas James <thejamesnick@github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thejamesnick/github-xp.git"
  },
  "bugs": {
    "url": "https://github.com/thejamesnick/github-xp/issues"
  },
  "homepage": "https://github.com/thejamesnick/github-xp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.4.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  }
}
